library(flexmix)
library(fpc)
library(sp)
library(raster)
library(maptools)
library(rgdal)
library(ncdf)
write("1.Terminado proceso de instalación y carga de paquetes", file="Error/process_info.txt", append=TRUE)
#Corrección de un posible 1x1 cuando se seleccione "europe"
if(pais=="Europe"){
resol1 <- "Celdas 5x5 km aprox (2.5 arc-min)"
}
#introducción tabla de lista de países a elegir
load("lista.paises.RData")
##Elemento introducido por el usuario: pais
pais<-subset(Paises,Denomina==paste(pais))
pais<-paste(pais[1,1])
##Elemento introducido por el usuario: resol1
load("resol.RData")
resol<-subset(resol,resolucion==paste(resol1))
resol<-as.character(resol[1,2])
load(paste("rdatapoints/",pais,"/",resol,"/base",resol,".RData",sep=""))
setwd("K:/rdatapoints/ecuador/1x1")
load("base1x1.RData")
setwd("K:/rdatapoints/spain/1x1")
load("base1x1.RData")
setwd("K:/rdatapoints/world/1x1")
setwd("K:/rdatapoints/world/10x10")
load("base1x1.RData")
load("base10x10.RData")
setwd("K:/rdatapoints/france/1x1")
load("base1x1.RData")
setwd("D:/elcmapas/rdatapoints/italy/1x1")
load("base1x1.RData")
setwd("D:/elcmapas/rdatapoints/spain/1x1")
load("base1x1.RData")
