setwd("D:/AmpliacionMapas")
load("lista.paises.Rdata")
View(lista.paises)
paises<-lista.paises[65:104,]
View(lista.paises)
View(paises)
load("lista.variables.Rdata")
variables<-lista.variables
setwd("D:/AmpliacionMapas/rdatamapsARCGIS")
library(raster)
library(rgdal)
library(sp)
library(maptools)
#Transformación de ASCII a grd a 1x1
for (i in 1:length(paises[,1])) {
for (j in 1:length(variables[,2])){
a1<-raster(paste(paises[i,1],"/1x1/",variables[j,2],".asc",sep=""))
setwd(paste("D:/AmpliacionMapas/rdatamaps/",paises[i,1],"/1x1/",sep=""))
writeRaster(a1,filename=paste(variables[j,2],".grd",sep=""),overwrite=T)
setwd("D:/AmpliacionMapas/rdatamapsARCGIS")
}
}
