setwd("C:/CAPFITOGEN3/Pasaporte")
TablaTotal<-read.delim("TablaTotal.txt")
TablaTaxa<-read.delim("TablaTaxa.txt")
?merge
colnames(TablaTaxa)
colnames(TablaTotal)
TablaFusion<-merge(TablaTotal,TablaTaxa,by.x="ESPECIE", by.y="Taxa.total",all.x=TRUE)
View(TablaFusion)
TablaFusion<-merge(TablaTotal,TablaTaxa,by.x="ESPECIE", by.y="Taxa.total",all=TRUE)
View(TablaFusion)
TablaTotal<-read.delim("TablaTotal.txt")
TablaTaxa<-read.delim("TablaTaxa.txt")
TablaFusion<-merge(TablaTotal,TablaTaxa,by="ESPECIE",all=TRUE)
View(TablaFusion)
TablaFusion<-merge(TablaTotal,TablaTaxa,by="ESPECIE",all.y=TRUE)
View(TablaFusion)
write.table(TablaFusion, file = "TablaFusion.xls", sep = "\t", row.names = FALSE, qmethod = "double")
